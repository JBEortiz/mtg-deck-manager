# SQLite database file path.
# Local dev example:
MTG_DB_PATH=.data/mtgdeckmanager-next.sqlite
# Production example (persistent writable volume):
# MTG_DB_PATH=/var/lib/mtgdeckmanager/mtgdeckmanager-next.sqlite

# Optional. Keep '/api' for same-origin API routing.
# Use an absolute https URL only if frontend and API are hosted separately.
NEXT_PUBLIC_API_BASE_URL=/api

# Optional cached FX rate for display conversion only (canonical prices remain USD)
# Example: 1 USD = 0.92 EUR
NEXT_PUBLIC_USD_TO_EUR=0.92

# Google OAuth (optional but required to enable Google sign-in/sign-up)
# Required: GOOGLE_OAUTH_CLIENT_ID + GOOGLE_OAUTH_CLIENT_SECRET
# Compatible aliases:
# - GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# - AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET
# Redirect behavior:
# - If GOOGLE_OAUTH_REDIRECT_URI is set, it is used as-is.
# - If missing, the app falls back to <request-origin>/api/auth/google/callback.
# - For proxy/hosted setups without stable request origin, set APP_BASE_URL.
# Register callback URLs in Google Cloud:
# - http://localhost:3000/api/auth/google/callback (dev)
# - https://<your-domain>/api/auth/google/callback (prod)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Base public URL for hosted/proxy setups (no trailing slash).
# Local:
APP_BASE_URL=http://localhost:3000
# Production:
# APP_BASE_URL=https://your-domain.com
